---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchAllWithCache, getPhotosByCategory as getSanityPhotosByCategory, urlFor } from '../../lib/sanity.js';
import { getCategories as getLocalCategories, getPhotosByCategory as getLocalPhotosByCategory } from '../../data/photos.js';

// ── Generate paths from Sanity → Cache → Local fallback ─────────
export async function getStaticPaths() {
  const { categories, source } = await fetchAllWithCache();

  if ((source === 'sanity' || source === 'cache') && categories && categories.length > 0) {
    return categories.map(cat => ({
      params: { slug: cat.slug },
      props: { categoryName: cat.name, source }
    }));
  }

  // Local fallback
  const localCats = getLocalCategories();
  return localCats.map(cat => ({
    params: { slug: cat.slug },
    props: { categoryName: cat.name, source: 'local' }
  }));
}

const { slug } = Astro.params;
const { categoryName, source } = Astro.props;

// ── Fetch photos for this category ──────────────────────────────
let photos = [];

if (source === 'cache') {
  // Use cache directly — don't hit Sanity API again per-category
  try {
    const { readCache } = await import('../../lib/sanity-cache.js');
    const cached = readCache();
    if (cached && cached.photos) {
      photos = cached.photos
        .filter(p => p.category?.slug === slug && p.image)
        .map(p => ({
          id:    p._id,
          title: p.title || 'Untitled',
          slug:  p.slug || p._id,
          img:   urlFor(p.image).width(800).quality(80).auto('format').url(),
          desc:  p.description || '',
          cat:   p.category?.name || categoryName
        }));
    }
  } catch (ce) {
    console.warn('Cache read failed for category:', slug, ce.message);
  }
} else if (source === 'sanity') {
  try {
    const sanityPhotos = await getSanityPhotosByCategory(slug);
    photos = sanityPhotos.map(p => ({
      id:    p._id,
      title: p.title || 'Untitled',
      slug:  p.slug || p._id,
      img:   p.image ? urlFor(p.image).width(800).quality(80).auto('format').url() : '',
      desc:  p.description || '',
      cat:   p.category?.name || categoryName
    })).filter(p => p.img);
  } catch (e) {
    console.warn('Sanity photos fetch failed for category:', slug, e.message);
  }
}

// Fallback to local
if (photos.length === 0) {
  photos = getLocalPhotosByCategory(slug);
}
---

<BaseLayout title={`${categoryName} — Alba Tull`} description={`Photography collection: ${categoryName}`}>
  <div class="grid-page">
    <div class="grid-header">
      <a class="grid-back" href="/">← Back to Portfolio</a>
      <h1 class="grid-title">{categoryName}</h1>
      <p class="grid-subtitle">{photos.length} photograph{photos.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="photo-grid">
      {photos.map(photo => (
        <a
          class="grid-tile"
          href={`/photo/${photo.slug}/`}
          data-overlay-link
          data-kind="photo"
          data-still={photo.img}
        >
          <img
            src={photo.img}
            alt={photo.title}
            loading="lazy"
            decoding="async"
          />
          <div class="grid-tile-title">{photo.title}</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
