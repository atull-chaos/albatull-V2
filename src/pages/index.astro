---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllWithCache, urlFor } from '../lib/sanity.js';
import { PHOTOS as LOCAL_PHOTOS, getCategories as getLocalCategories, catSlug as makeCatSlug } from '../data/photos.js';

// ── Fetch from Sanity → Cache → Local fallback ──────────────────
let photos = [];
let categories = [];
let featuredPhoto = null;

const { photos: rawPhotos, categories: rawCats, featured: rawFeatured, source } = await fetchAllWithCache();

if ((source === 'sanity' || source === 'cache') && rawPhotos) {
  photos = rawPhotos.map(p => ({
    id:    p._id,
    title: p.title || 'Untitled',
    cat:   p.category?.name || 'Uncategorized',
    catSlug: p.category?.slug || '',
    slug:  p.slug || p._id,
    img:   p.image ? urlFor(p.image).width(800).quality(80).auto('format').url() : '',
    desc:  p.description || ''
  })).filter(p => p.img);

  categories = (rawCats || []).map(c => ({
    name:  c.name,
    slug:  c.slug,
    count: c.photoCount || 0
  }));

  if (rawFeatured && rawFeatured.image) {
    featuredPhoto = {
      title: rawFeatured.title || 'Untitled',
      cat:   rawFeatured.category?.name || '',
      img:   urlFor(rawFeatured.image).width(1200).quality(90).auto('format').url(),
      slug:  rawFeatured.slug || ''
    };
  }
} else {
  photos = LOCAL_PHOTOS.map(p => ({
    ...p,
    catSlug: makeCatSlug(p.cat)
  }));
  categories = getLocalCategories();
}

// Fallback featured photo if none marked in Sanity
if (!featuredPhoto && photos.length > 0) {
  featuredPhoto = {
    title: photos[0].title,
    cat:   photos[0].cat,
    img:   photos[0].img,
    slug:  photos[0].slug
  };
}

// Pick a striking photo for the left palette column
// Use a botanical or abstract photo if available, otherwise a random one
const botanicalPhotos = photos.filter(p => p.cat?.toLowerCase().includes('botanical'));
const palettePhoto = botanicalPhotos.length > 0
  ? botanicalPhotos[Math.floor(Math.random() * botanicalPhotos.length)]
  : photos[Math.floor(Math.random() * photos.length)];
---

<BaseLayout title="Alba Tull - Photography Portfolio">
  <div class="home-layout">
    <!-- Left: Image with Abstract Color Palette Background -->
    <div class="palette-column">
      <canvas id="paletteCanvas" class="palette-canvas"></canvas>
      <div class="palette-image-wrap">
        <img
          id="paletteImg"
          class="palette-image"
          src={palettePhoto?.img}
          alt={palettePhoto?.title || ''}
          crossorigin="anonymous"
        />
      </div>
      <div class="palette-overlay">
        <span class="palette-text">ENTRY PAGE</span>
      </div>
    </div>

    <!-- Right: Featured Photo + Branding -->
    <div class="hero-panel">
      <div class="hero-featured-wrap">
        <div class="hero-featured">
          <div class="hero-featured-label">Featured Photo</div>
          <a href={featuredPhoto?.slug ? `/photo/${featuredPhoto.slug}/` : '#'}>
            <img
              id="heroFeaturedImg"
              src={featuredPhoto?.img}
              alt={featuredPhoto?.title}
              crossorigin="anonymous"
            />
          </a>
          <div class="hero-featured-title">{featuredPhoto?.title}</div>
          <div class="hero-featured-cat">{featuredPhoto?.cat}</div>
        </div>
      </div>

      <!-- Branding -->
      <div class="hero-branding">
        <div class="hero-name">Alba Tull</div>
        <div class="hero-subtitle">Photography Portfolio of Work (2005—2025)</div>

        <div class="hero-meta">
          <div class="hero-meta-item"><strong>{photos.length}</strong> Artworks</div>
          <div class="hero-meta-item"><strong>{categories.length}</strong> Categories</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // === Abstract Color Palette Generator ===
    // Extracts dominant colors from the palette image (left column photo)
    // and paints a blurred, abstract composition behind it on the canvas.

    function extractColors(img, sampleSize) {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      canvas.width = sampleSize;
      canvas.height = sampleSize;
      ctx.drawImage(img, 0, 0, sampleSize, sampleSize);
      const data = ctx.getImageData(0, 0, sampleSize, sampleSize).data;

      // Collect color samples
      const colors = [];
      for (let i = 0; i < data.length; i += 4 * 3) {
        colors.push([data[i], data[i+1], data[i+2]]);
      }

      // Simple k-means-ish: bucket by hue regions
      const buckets = {};
      colors.forEach(([r, g, b]) => {
        const max = Math.max(r, g, b);
        const min = Math.min(r, g, b);
        let hue = 0;
        if (max !== min) {
          if (max === r) hue = ((g - b) / (max - min)) % 6;
          else if (max === g) hue = (b - r) / (max - min) + 2;
          else hue = (r - g) / (max - min) + 4;
        }
        hue = Math.round(((hue * 60) + 360) % 360);
        const bucket = Math.floor(hue / 30);
        const sat = max === 0 ? 0 : (max - min) / max;
        const val = max / 255;

        if (!buckets[bucket]) buckets[bucket] = { r: 0, g: 0, b: 0, count: 0, sat: 0, val: 0 };
        buckets[bucket].r += r;
        buckets[bucket].g += g;
        buckets[bucket].b += b;
        buckets[bucket].sat += sat;
        buckets[bucket].val += val;
        buckets[bucket].count++;
      });

      // Get top 6 dominant color buckets
      const sorted = Object.values(buckets)
        .filter(b => b.count > 5)
        .sort((a, b) => b.count - a.count)
        .slice(0, 6)
        .map(b => ({
          r: Math.round(b.r / b.count),
          g: Math.round(b.g / b.count),
          b: Math.round(b.b / b.count),
          sat: b.sat / b.count,
          val: b.val / b.count,
          weight: b.count
        }));

      return sorted;
    }

    function paintPalette(canvas, colors) {
      const ctx = canvas.getContext('2d');
      const w = canvas.width = canvas.offsetWidth * 2; // 2x for retina
      const h = canvas.height = canvas.offsetHeight * 2;

      // Fill with the most dominant color as base
      if (colors.length === 0) {
        ctx.fillStyle = '#e8e4e0';
        ctx.fillRect(0, 0, w, h);
        return;
      }

      const bg = colors[0];
      ctx.fillStyle = `rgb(${bg.r}, ${bg.g}, ${bg.b})`;
      ctx.fillRect(0, 0, w, h);

      // Paint large, soft, overlapping shapes for each color
      colors.forEach((c, i) => {
        const numBlobs = 2 + Math.floor(Math.random() * 3);
        for (let j = 0; j < numBlobs; j++) {
          const x = Math.random() * w;
          const y = Math.random() * h;
          const radius = (0.2 + Math.random() * 0.5) * Math.min(w, h);

          const grad = ctx.createRadialGradient(x, y, 0, x, y, radius);
          const alpha = 0.15 + Math.random() * 0.35;
          grad.addColorStop(0, `rgba(${c.r}, ${c.g}, ${c.b}, ${alpha})`);
          grad.addColorStop(0.5, `rgba(${c.r}, ${c.g}, ${c.b}, ${alpha * 0.4})`);
          grad.addColorStop(1, `rgba(${c.r}, ${c.g}, ${c.b}, 0)`);

          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, w, h);
        }
      });

      // Add a gentle film grain texture
      const imageData = ctx.getImageData(0, 0, w, h);
      const pixels = imageData.data;
      for (let i = 0; i < pixels.length; i += 4) {
        const noise = (Math.random() - 0.5) * 15;
        pixels[i] += noise;
        pixels[i+1] += noise;
        pixels[i+2] += noise;
      }
      ctx.putImageData(imageData, 0, 0);

      // Final soft blur pass via CSS (canvas itself gets filter)
    }

    // Extract colors from the palette image (left column) to paint the abstract background
    const paletteImg = document.getElementById('paletteImg');
    const paletteCanvas = document.getElementById('paletteCanvas');

    if (paletteImg && paletteCanvas) {
      function generate() {
        try {
          const colors = extractColors(paletteImg, 64);
          paintPalette(paletteCanvas, colors);
        } catch (e) {
          // CORS or other error — paint neutral fallback
          const ctx = paletteCanvas.getContext('2d');
          const w = paletteCanvas.width = paletteCanvas.offsetWidth * 2;
          const h = paletteCanvas.height = paletteCanvas.offsetHeight * 2;
          const grad = ctx.createLinearGradient(0, 0, w, h);
          grad.addColorStop(0, '#e8e4e0');
          grad.addColorStop(0.5, '#d4cfc8');
          grad.addColorStop(1, '#f0ece8');
          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, w, h);
        }
      }

      if (paletteImg.complete) {
        generate();
      } else {
        paletteImg.addEventListener('load', generate);
      }

      // Regenerate on resize
      window.addEventListener('resize', () => {
        if (paletteImg.complete) generate();
      });
    }
  </script>
</BaseLayout>
