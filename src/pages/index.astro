---
import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAllWithCache, urlFor } from '../lib/sanity.js';
import { PHOTOS as LOCAL_PHOTOS, getCategories as getLocalCategories, catSlug as makeCatSlug } from '../data/photos.js';

// ── Fetch from Sanity → Cache → Local fallback ──────────────────
let photos = [];
let categories = [];
let featuredPhoto = null;

const { photos: rawPhotos, categories: rawCats, featured: rawFeatured, source } = await fetchAllWithCache();

if (source === 'sanity' && rawPhotos) {
  // Live Sanity data — transform with urlFor
  photos = rawPhotos.map(p => ({
    id:    p._id,
    title: p.title || 'Untitled',
    cat:   p.category?.name || 'Uncategorized',
    catSlug: p.category?.slug || '',
    slug:  p.slug || p._id,
    img:   p.image ? urlFor(p.image).width(800).quality(80).auto('format').url() : '',
    desc:  p.description || ''
  })).filter(p => p.img);

  categories = rawCats.map(c => ({
    name:  c.name,
    slug:  c.slug,
    count: c.photoCount || 0
  }));

  if (rawFeatured && rawFeatured.image) {
    featuredPhoto = {
      title: rawFeatured.title || 'Untitled',
      cat:   rawFeatured.category?.name || '',
      img:   urlFor(rawFeatured.image).width(1000).quality(85).auto('format').url(),
      slug:  rawFeatured.slug || ''
    };
  }
} else if (source === 'cache' && rawPhotos) {
  // Cached data — images already have full URLs from previous build
  photos = rawPhotos.map(p => ({
    id:    p._id,
    title: p.title || 'Untitled',
    cat:   p.category?.name || 'Uncategorized',
    catSlug: p.category?.slug || '',
    slug:  p.slug || p._id,
    img:   p.image ? urlFor(p.image).width(800).quality(80).auto('format').url() : '',
    desc:  p.description || ''
  })).filter(p => p.img);

  categories = (rawCats || []).map(c => ({
    name:  c.name,
    slug:  c.slug,
    count: c.photoCount || 0
  }));

  if (rawFeatured && rawFeatured.image) {
    featuredPhoto = {
      title: rawFeatured.title || 'Untitled',
      cat:   rawFeatured.category?.name || '',
      img:   urlFor(rawFeatured.image).width(1000).quality(85).auto('format').url(),
      slug:  rawFeatured.slug || ''
    };
  }
} else {
  // Local fallback (no Sanity, no cache)
  photos = LOCAL_PHOTOS.map(p => ({
    ...p,
    catSlug: makeCatSlug(p.cat)
  }));
  categories = getLocalCategories();
}

// Fallback featured photo if none marked in Sanity
if (!featuredPhoto && photos.length > 0) {
  featuredPhoto = {
    title: photos[0].title,
    cat:   photos[0].cat,
    img:   photos[0].img,
    slug:  photos[0].slug
  };
}
---

<BaseLayout title="Alba Tull - Photography Portfolio">
  <div class="home-layout">
    <!-- Left: Rolodex -->
    <div class="rolodex-column">
      <div class="rolodex-scroll">
        <div class="rolodex-spacer">
          <div class="rolodex-sticky">
            <div class="rolodex-perspective" id="roloWrapper">
              <!-- Cards injected by script below -->
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Hero Panel -->
    <div class="hero-panel">
      <!-- Featured Photo — centered, prominent -->
      <div class="hero-featured-wrap">
        <div class="hero-featured">
          <div class="hero-featured-label">Picture of the Moment</div>
          <a href={featuredPhoto?.slug ? `/photo/${featuredPhoto.slug}/` : '#'}>
            <img
              id="heroFeaturedImg"
              src={featuredPhoto?.img}
              alt={featuredPhoto?.title}
            />
          </a>
          <div class="hero-featured-title">{featuredPhoto?.title}</div>
          <div class="hero-featured-cat">{featuredPhoto?.cat}</div>
        </div>
      </div>

      <!-- Branding -->
      <div class="hero-branding">
        <div class="hero-name">Alba Tull</div>
        <div class="hero-subtitle">Photography Portfolio of Work (2005—2025)</div>

        <div class="hero-meta">
          <div class="hero-meta-item"><strong>{photos.length}</strong> Artworks</div>
          <div class="hero-meta-item"><strong>{categories.length}</strong> Categories</div>
        </div>
      </div>
    </div>

    <!-- Hidden info targets for rolodex scroll (used by JS) -->
    <div style="display:none">
      <span id="infoCategory"></span>
      <span id="infoTitle"></span>
      <span id="infoDesc"></span>
    </div>
  </div>

  <script define:vars={{ photos }}>
    // === ROLODEX CIRCULAR WHEEL v5 — tighter, compact ===
    // Per-card perspective for Firefox fix. Native scroll for smoothness.

    // Scale radius to viewport height so cards fill the wheel on any screen
    var baseRadius = Math.max(320, Math.min(600, window.innerHeight * 0.52));
    var RADIUS = baseRadius;
    var CARD_GAP_DEG = 22;
    var VISIBLE_CARDS = 11;
    var HALF_VISIBLE = Math.floor(VISIBLE_CARDS / 2);
    var SCROLL_PER_CARD = 150;
    var PERSPECTIVE = 1000;
    var LOOP_BUFFER = 50;
    var CARD_GAP_RAD = CARD_GAP_DEG * Math.PI / 180;

    function posMod(n, m) { return ((n % m) + m) % m; }

    var scrollContainer = document.querySelector('.rolodex-scroll');
    var spacer = document.querySelector('.rolodex-spacer');
    var wrapper = document.querySelector('.rolodex-perspective');

    if (scrollContainer && spacer && wrapper && photos.length) {
      var total = photos.length;

      wrapper.style.perspective = 'none';
      wrapper.style.transformStyle = 'flat';

      // Only preload the first ~30 images (nearby cards), not all 594
      var preloadCount = Math.min(30, total);
      for (var pi = 0; pi < preloadCount; pi++) {
        var preImg = new Image();
        preImg.src = photos[pi].img;
      }

      var totalScrollItems = total * LOOP_BUFFER;
      var totalScrollHeight = totalScrollItems * SCROLL_PER_CARD;
      spacer.style.height = totalScrollHeight + 'px';

      var startScroll = Math.floor(totalScrollItems / 2) * SCROLL_PER_CARD;
      scrollContainer.scrollTop = startScroll - (startScroll % (total * SCROLL_PER_CARD));

      var cards = [];
      for (var i = 0; i < VISIBLE_CARDS; i++) {
        var sheet = document.createElement('div');
        sheet.className = 'rolo-card';
        sheet.style.transformStyle = 'flat';
        sheet.innerHTML = '<div class="rolo-media"><img class="rolo-img" src="" alt="" loading="eager"></div><div class="rolo-label"></div>';
        wrapper.appendChild(sheet);
        cards.push(sheet);
      }

      var currentIndex = -1;

      function update() {
        var scrollTop = scrollContainer.scrollTop;
        var floatIndex = scrollTop / SCROLL_PER_CARD;
        var baseIndex = Math.floor(floatIndex);
        var fraction = floatIndex - baseIndex;
        var centerPhotoIdx = posMod(baseIndex, total);

        // Update "Now Viewing" text only — hero featured image stays fixed
        if (centerPhotoIdx !== currentIndex) {
          currentIndex = centerPhotoIdx;
          var p = photos[currentIndex];
          document.getElementById('infoCategory').textContent = p.cat;
          document.getElementById('infoTitle').textContent = p.title;
          document.getElementById('infoDesc').textContent = p.desc;
        }

        for (var slot = 0; slot < VISIBLE_CARDS; slot++) {
          var offset = slot - HALF_VISIBLE;
          var sheetEl = cards[slot];
          var photoIdx = posMod(baseIndex + offset, total);
          var photo = photos[photoIdx];
          var dist = offset - fraction;
          var angle = dist * CARD_GAP_RAD;

          var y = RADIUS * Math.sin(angle);
          var z = RADIUS * Math.cos(angle) - RADIUS;
          var rotXDeg = angle * (180 / Math.PI);

          sheetEl.style.visibility = 'visible';

          sheetEl.style.transform = 'perspective(' + PERSPECTIVE + 'px) translateY(' + y + 'px) translateZ(' + z + 'px) rotateX(' + rotXDeg + 'deg)';
          sheetEl.style.transformOrigin = 'center center';
          sheetEl.style.zIndex = Math.round(50 + 50 * Math.cos(angle));

          var isFront = Math.abs(angle) < 0.4;
          sheetEl.style.pointerEvents = isFront ? 'auto' : 'none';

          // Tighter fade — cards disappear sooner for cleaner look
          var absDist = Math.abs(dist);
          var opacity;
          if (absDist < 1.5) { opacity = 1; }
          else if (absDist < 2.2) { opacity = 1 - (absDist - 1.5) / 0.7; }
          else { opacity = 0; }
          sheetEl.style.opacity = opacity;

          var img = sheetEl.querySelector('.rolo-img');
          if (img && img.getAttribute('src') !== photo.img) {
            img.src = photo.img;
            img.alt = photo.title;
          }
          var label = sheetEl.querySelector('.rolo-label');
          if (label) {
            label.textContent = photo.cat;
            label.style.opacity = isFront ? 1 : 0;
          }

          (function(pi, ph) {
            sheetEl.onclick = function() {
              // Navigate to the photo's detail page directly
              if (ph.slug) {
                window.location.href = '/photo/' + ph.slug + '/';
              } else if (ph.catSlug) {
                window.location.href = '/category/' + ph.catSlug + '/';
              }
            };
          })(photoIdx, photo);
        }

        var oneLoop = total * SCROLL_PER_CARD;
        if (scrollTop < oneLoop * 5) {
          scrollContainer.scrollTop = scrollTop + oneLoop * (LOOP_BUFFER / 2);
        } else if (scrollTop > totalScrollHeight - oneLoop * 5) {
          scrollContainer.scrollTop = scrollTop - oneLoop * (LOOP_BUFFER / 2);
        }
      }

      var ticking = false;
      scrollContainer.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() { update(); ticking = false; });
          ticking = true;
        }
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
          e.preventDefault();
          scrollContainer.scrollBy({ top: -SCROLL_PER_CARD, behavior: 'smooth' });
        }
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
          e.preventDefault();
          scrollContainer.scrollBy({ top: SCROLL_PER_CARD, behavior: 'smooth' });
        }
      });

      update();
    }
  </script>
</BaseLayout>
