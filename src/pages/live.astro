---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder video clips from Pexels (free stock, royalty-free)
// Each card has a FRONT video (wider/establishing) and BACK video (close-up/detail)
// User will replace with their own archive footage
const videos = [
  {
    title: 'Botanical',
    subtitle: 'Macro Studies',
    frontVideo: 'https://videos.pexels.com/video-files/3864103/3864103-hd_1920_1080_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/3150344/3150344-uhd_2732_1440_25fps.mp4'
  },
  {
    title: 'Ocean',
    subtitle: 'Tidal Rhythms',
    frontVideo: 'https://videos.pexels.com/video-files/1390942/1390942-uhd_2732_1440_24fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/1181911/1181911-hd_1920_1080_30fps.mp4'
  },
  {
    title: 'Urban Flow',
    subtitle: 'City Rhythms',
    frontVideo: 'https://videos.pexels.com/video-files/5544054/5544054-hd_1920_1080_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/6529560/6529560-hd_1920_1080_30fps.mp4'
  },
  {
    title: 'Abstract',
    subtitle: 'Color in Movement',
    frontVideo: 'https://videos.pexels.com/video-files/3051358/3051358-hd_1920_1080_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/9668753/9668753-hd_1920_1080_30fps.mp4'
  },
  {
    title: 'Aerial',
    subtitle: 'Above the Terrain',
    frontVideo: 'https://videos.pexels.com/video-files/29138481/29138481-uhd_2560_1440_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/6772135/6772135-hd_1920_1080_30fps.mp4'
  },
  {
    title: 'Texture',
    subtitle: 'Material & Form',
    frontVideo: 'https://videos.pexels.com/video-files/4623748/4623748-hd_1920_1080_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/6577871/6577871-hd_1920_1080_30fps.mp4'
  },
  {
    title: 'Architecture',
    subtitle: 'Structure & Shadow',
    frontVideo: 'https://videos.pexels.com/video-files/4995563/4995563-hd_1920_1080_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/32236967/32236967-hd_1920_1080_30fps.mp4'
  },
  {
    title: 'Golden Hour',
    subtitle: 'Light & Silhouette',
    frontVideo: 'https://videos.pexels.com/video-files/34204590/34204590-uhd_2560_1440_30fps.mp4',
    backVideo:  'https://videos.pexels.com/video-files/4183292/4183292-hd_1920_1080_30fps.mp4'
  }
];
---

<BaseLayout title="Live — Alba Tull">
  <div class="live-page">
    <div class="live-header">
      <h1 class="live-title">Motion</h1>
      <p class="live-subtitle">Moving images & live captures</p>
    </div>

    <div class="flip-cards-container">
      {videos.map((v, i) => (
        <div class="flip-card" data-index={i}>
          <div class="flip-card-inner">
            <!-- Front: establishing/wide video -->
            <div class="flip-card-front">
              <video
                src={v.frontVideo}
                muted
                loop
                playsinline
                preload="none"
              ></video>
              <div class="flip-card-label">
                <h2>{v.title}</h2>
                <span>{v.subtitle}</span>
              </div>
            </div>
            <!-- Back: close-up/detail video (revealed on flip) -->
            <div class="flip-card-back">
              <video
                src={v.backVideo}
                muted
                loop
                playsinline
                preload="none"
              ></video>
              <div class="flip-card-label">
                <h2>{v.title}</h2>
                <span>{v.subtitle}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    // === Flip Card Controller ===
    // Both sides have video. Front video plays when card is visible (not flipped).
    // When the card flips (scroll into center or hover), the back video plays
    // and the front video pauses. Uses IntersectionObserver for viewport-aware playback.

    const cards = document.querySelectorAll('.flip-card');

    function setCardState(card, flipped) {
      const frontVideo = card.querySelector('.flip-card-front video');
      const backVideo = card.querySelector('.flip-card-back video');

      if (flipped) {
        card.classList.add('is-flipped');
        if (frontVideo) frontVideo.pause();
        if (backVideo) backVideo.play().catch(() => {});
      } else {
        card.classList.remove('is-flipped');
        if (backVideo) backVideo.pause();
        // Only play front video if card is in viewport
        if (frontVideo && card.dataset.inView === 'true') {
          frontVideo.play().catch(() => {});
        }
      }
    }

    // Track viewport visibility
    const viewObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target;
        const frontVideo = card.querySelector('.flip-card-front video');
        const backVideo = card.querySelector('.flip-card-back video');

        if (entry.isIntersecting) {
          card.dataset.inView = 'true';
          // Start the front video playing as soon as card enters viewport
          if (!card.classList.contains('is-flipped') && frontVideo) {
            frontVideo.play().catch(() => {});
          }
        } else {
          card.dataset.inView = 'false';
          // Pause everything and un-flip when out of view
          if (frontVideo) frontVideo.pause();
          if (backVideo) backVideo.pause();
          card.classList.remove('is-flipped');
        }
      });
    }, {
      threshold: [0, 0.2],
      rootMargin: '50px 0px'
    });

    // Flip cards when they reach the center of the viewport
    const flipObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target;
        if (entry.isIntersecting && entry.intersectionRatio > 0.5) {
          setCardState(card, true);
        } else if (!entry.isIntersecting || entry.intersectionRatio < 0.2) {
          // Only un-flip if not hovered
          if (!card.matches(':hover')) {
            setCardState(card, false);
          }
        }
      });
    }, {
      threshold: [0, 0.2, 0.5, 0.8],
      rootMargin: '-20% 0px -20% 0px'
    });

    cards.forEach(card => {
      viewObserver.observe(card);
      flipObserver.observe(card);

      // Also flip on hover
      card.addEventListener('mouseenter', () => {
        setCardState(card, true);
      });

      card.addEventListener('mouseleave', () => {
        // Only un-flip if not prominently centered in viewport
        const rect = card.getBoundingClientRect();
        const vh = window.innerHeight;
        const centerY = rect.top + rect.height / 2;
        const isCenter = centerY > vh * 0.3 && centerY < vh * 0.7;
        if (!isCenter) {
          setCardState(card, false);
        }
      });
    });
  </script>
</BaseLayout>
