---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder video clips from Pexels (free stock, royalty-free)
// SAME video plays on both front and back faces, with the back
// offset by a few seconds — so when the card flips, you see a
// different moment of the same footage. Always in motion.
// User will replace with their own archive footage.
const videos = [
  {
    title: 'Botanical',
    subtitle: 'Macro Studies',
    video: 'https://videos.pexels.com/video-files/3864103/3864103-hd_1920_1080_30fps.mp4',
    offset: 4
  },
  {
    title: 'Ocean',
    subtitle: 'Tidal Rhythms',
    video: 'https://videos.pexels.com/video-files/1390942/1390942-uhd_2732_1440_24fps.mp4',
    offset: 5
  },
  {
    title: 'Urban Flow',
    subtitle: 'City Rhythms',
    video: 'https://videos.pexels.com/video-files/5544054/5544054-hd_1920_1080_30fps.mp4',
    offset: 3
  },
  {
    title: 'Natural Light',
    subtitle: 'Golden Hour Series',
    video: 'https://videos.pexels.com/video-files/857251/857251-hd_1920_1080_25fps.mp4',
    offset: 4
  },
  {
    title: 'Atmosphere',
    subtitle: 'Mood & Texture',
    video: 'https://videos.pexels.com/video-files/856974/856974-hd_1920_1080_30fps.mp4',
    offset: 3
  },
  {
    title: 'Aerial',
    subtitle: 'Above the Terrain',
    video: 'https://videos.pexels.com/video-files/1093662/1093662-uhd_2560_1440_30fps.mp4',
    offset: 5
  },
  {
    title: 'Abstract',
    subtitle: 'Color in Movement',
    video: 'https://videos.pexels.com/video-files/854669/854669-hd_1920_1080_30fps.mp4',
    offset: 4
  },
  {
    title: 'Golden Hour',
    subtitle: 'Light & Silhouette',
    video: 'https://videos.pexels.com/video-files/2257010/2257010-hd_1920_1080_25fps.mp4',
    offset: 3
  }
];
---

<BaseLayout title="Live — Alba Tull">
  <div class="live-page">
    <div class="live-header">
      <h1 class="live-title">Motion</h1>
      <p class="live-subtitle">Moving images & live captures</p>
    </div>

    <div class="flip-cards-container">
      {videos.map((v, i) => (
        <div class="flip-card" data-index={i} data-offset={v.offset}>
          <div class="flip-card-inner">
            <!-- Front: video playing from 0:00 -->
            <div class="flip-card-front">
              <video
                src={v.video}
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
              <div class="flip-card-label">
                <h2>{v.title}</h2>
                <span>{v.subtitle}</span>
              </div>
            </div>
            <!-- Back: SAME video, offset by a few seconds -->
            <div class="flip-card-back">
              <video
                src={v.video}
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
              <div class="flip-card-label">
                <h2>{v.title}</h2>
                <span>{v.subtitle}</span>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script>
    // === Flip Card Controller — Always in Motion ===
    // Both faces show the SAME video. The back face is offset by a few
    // seconds so when the card flips, you see a different moment of the
    // same footage. Both videos play simultaneously when in viewport.
    // Inspired by MarkClennon.com/motion — everything is always moving.

    const cards = document.querySelectorAll('.flip-card');

    // ── Initialize back-video time offsets ──────────────────────────
    cards.forEach(card => {
      const backVideo = card.querySelector('.flip-card-back video');
      const offset = parseInt(card.dataset.offset) || 4;
      if (backVideo) {
        // Set the offset once the video metadata is loaded
        backVideo.addEventListener('loadedmetadata', () => {
          backVideo.currentTime = Math.min(offset, backVideo.duration * 0.4);
        }, { once: true });
      }
    });

    // ── Wave motion on scroll ──────────────────────────────────────
    let ticking = false;
    function updateWave() {
      const vh = window.innerHeight;
      cards.forEach((card, i) => {
        const rect = card.getBoundingClientRect();
        const centerY = rect.top + rect.height / 2;
        const progress = centerY / vh;
        const wave = Math.sin(progress * Math.PI) * 6;
        const tiltDir = i % 2 === 0 ? 1 : -1;
        const tilt = Math.sin(progress * Math.PI * 1.2) * 0.8 * tiltDir;
        card.style.transform = `translateY(${wave}px) rotateZ(${tilt}deg)`;
      });
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateWave);
        ticking = true;
      }
    }, { passive: true });
    updateWave();

    // ── Viewport visibility — play/pause both videos ───────────────
    const viewObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target;
        const frontVideo = card.querySelector('.flip-card-front video');
        const backVideo = card.querySelector('.flip-card-back video');

        if (entry.isIntersecting) {
          card.dataset.inView = 'true';
          // Play BOTH videos so the back is already rolling when it flips
          if (frontVideo) frontVideo.play().catch(() => {});
          if (backVideo) backVideo.play().catch(() => {});
        } else {
          card.dataset.inView = 'false';
          if (frontVideo) frontVideo.pause();
          if (backVideo) backVideo.pause();
          // Un-flip when fully out of view
          card.classList.remove('is-flipped');
        }
      });
    }, {
      threshold: [0, 0.15],
      rootMargin: '100px 0px'
    });

    // ── Flip when card reaches center of viewport ──────────────────
    const flipObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target;
        if (entry.isIntersecting && entry.intersectionRatio >= 0.35) {
          card.classList.add('is-flipped');
        } else if (!entry.isIntersecting || entry.intersectionRatio < 0.15) {
          if (!card.matches(':hover')) {
            card.classList.remove('is-flipped');
          }
        }
      });
    }, {
      threshold: [0, 0.15, 0.35, 0.6],
      rootMargin: '-10% 0px -10% 0px'
    });

    cards.forEach(card => {
      viewObserver.observe(card);
      flipObserver.observe(card);

      // Hover flip
      card.addEventListener('mouseenter', () => {
        card.classList.add('is-flipped');
      });

      card.addEventListener('mouseleave', () => {
        const rect = card.getBoundingClientRect();
        const vh = window.innerHeight;
        const centerY = rect.top + rect.height / 2;
        const isCenter = centerY > vh * 0.3 && centerY < vh * 0.7;
        if (!isCenter) {
          card.classList.remove('is-flipped');
        }
      });
    });
  </script>
</BaseLayout>
